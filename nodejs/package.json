{
  "name": "treebark-workspace",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/treebark && npm run build --workspace=packages/markdown-it-treebark && npm run build --workspace=packages/playground && npm run build --workspace=packages/markdown-it-playground && npm run build --workspace=packages/test",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces",
    "bump:all": "node scripts/bump-all-packages.mjs",
    "publish:all": "node scripts/publish-all-packages.mjs",
    "publish:all:dry-run": "node scripts/publish-all-packages.mjs --dry-run",
    "publish:all:dry-run:local": "node scripts/publish-all-packages.mjs --dry-run --ignore-scripts --skip-whoami"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^13.0.9",
    "cross-env": "^7.0.3",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.11"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "jsdom": "^26.1.0"
  }
}
